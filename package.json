{
  "name": "weggo-marketplace",
  "version": "1.0.0",
  "description": "AI-powered second-hand marketplace for Egypt",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "npm run lint:types && npm run lint:eslint",
    "lint:types": "next typegen && tsc --noEmit",
    "lint:eslint": "eslint app components lib tests e2e --ext .ts,.tsx",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "seed:featured": "tsx scripts/seed-featured.ts",
    "seed:trash": "tsx scripts/seed-trash.ts",
    "seed:trash:delete": "tsx scripts/seed-trash.ts --delete"
  },
  "dependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "express-rate-limit": "^8.3.2",
    "framer-motion": "^12.38.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "mongoose": "^9.4.1",
    "multer": "^2.1.1",
    "next": "^16.2.3",
    "node-cache": "^5.1.2",
    "postcss": "^8.5.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "mongodb-memory-server": "^11.0.1",
    "tsx": "^4.21.0",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "sucrase": "3.35.1"
  }
}
