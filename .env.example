MONGODB_URI=mongodb://localhost:27017/weggo
JWT_SECRET=replace-with-a-long-random-secret
# Secret pepper for hashing seller national IDs (HMAC-SHA256). Required in production.
# Generate once and keep stable: `openssl rand -hex 32`. The same value must be
# used by the app and by scripts/migrate-national-id-hash.ts.
NATIONAL_ID_HASH_SECRET=replace-with-openssl-rand-hex-32
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: only needed if you want server-side self-fetches to use an explicit origin
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: extracted production chatbot service proxy
CHATBOT_API_URL=http://127.0.0.1:5050
LANCEDB_API_URL=http://127.0.0.1:5000
TRANSLATION_API_URL=http://127.0.0.1:8000
INTERNAL_SERVICE_TOKEN=
AI_CHAT_SESSION_SECRET=
GOOGLE_API_KEY=
MONGO_URI=mongodb://127.0.0.1:27017
DB_NAME=weggo
SESSIONS_COLLECTION=sessions
LANCEDB_URI=./lancedb/semantic-lancedb-qwen3-emb
EMBED_API_BASE=http://127.0.0.1:8080/v1
SESSION_TTL_SECS=1800
EMBED_MODEL_NAME=dengcao/Qwen3-Embedding-0.6B:Q8_0
EMBED_QUERY_INSTRUCTION=Given a query, retrieve relevant passages that answer the query
EMBED_BATCH_SIZE=128
MAX_BATCH_SIZE=128
MAX_LISTINGS_PER_REQUEST=50

# Optional: password reset email support
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Optional: admin/seed helpers
SEED_ADMIN_SECRET=
SEED_FEATURED_SECRET=
SEED_SELLER_EMAIL=
SEED_SELLER_PASSWORD=
SEED_SELLER_NAME=

# Optional: debug helpers
DEBUG_COOKIES_SECRET=
DEBUG=
