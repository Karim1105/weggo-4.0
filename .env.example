# Core app
MONGODB_URI=mongodb://localhost:27017/weggo
JWT_SECRET=replace_with_a_long_random_secret

# Public URLs currently referenced by the app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional email/reset-link support
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Optional admin/dev helpers
SEED_ADMIN_SECRET=replace_with_admin_seed_secret
SEED_FEATURED_SECRET=replace_with_featured_seed_secret
SEED_SELLER_EMAIL=seed-seller@weggo.local
SEED_SELLER_PASSWORD=SeedSeller123!
SEED_SELLER_NAME=Weggo Featured Seller
DEBUG_COOKIES_SECRET=replace_with_debug_secret
DEBUG=false
